{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://fortify.skill/findings.schema.json",
  "title": "Fortify Security Findings",
  "type": "object",
  "required": ["run", "findings"],
  "properties": {
    "run": {
      "type": "object",
      "required": ["tier", "timestamp", "targets"],
      "properties": {
        "tier": { "enum": ["basic", "standard", "hardened", "maximum"] },
        "timestamp": { "type": "string", "format": "date-time" },
        "fixPolicy": { "enum": ["report-first", "auto-harden", "report-only"] },
        "frameworks": {
          "type": "array",
          "items": { "type": "string" },
          "description": "e.g. OWASP-ASVS, OWASP-Top10, NIST-CSF, NIST-800-53, CIS, SOC2, ISO27001, PCI-DSS"
        },
        "targets": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Authorized targets tested (e.g. localhost:3000, staging url)"
        },
        "authorizationBasisType": {
          "enum": ["self-attested-owner", "employer-authorization", "pentest-agreement", "bug-bounty-in-scope", "localhost-only", "other"],
          "description": "Structured authorization basis; forces the question to be asked rather than free-texted away."
        },
        "authorizationBasis": { "type": "string", "description": "Free-text detail of the authorization (who/what scope)." },
        "secretsRedacted": {
          "type": "boolean",
          "description": "Audit trail: set true once the secret-pattern redaction pass has run over this output."
        },
        "tools": { "type": "array", "items": { "type": "string" } },
        "swarmAgents": { "type": "array", "items": { "type": "string" } }
      }
    },
    "summary": {
      "type": "object",
      "properties": {
        "critical": { "type": "integer" },
        "high": { "type": "integer" },
        "medium": { "type": "integer" },
        "low": { "type": "integer" },
        "info": { "type": "integer" },
        "postureStatement": { "type": "string" },
        "residualRisk": { "type": "string" }
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "title", "severity", "status", "location", "description", "remediation"],
        "properties": {
          "id": { "type": "string", "pattern": "^F-[0-9]{3,}$" },
          "title": { "type": "string" },
          "severity": { "enum": ["critical", "high", "medium", "low", "info"] },
          "confidence": { "enum": ["confirmed", "potential"] },
          "cvss": { "type": "string", "description": "Optional CVSS vector/score" },
          "status": { "enum": ["open", "fixed-in-run", "accepted-risk", "wont-fix"] },
          "attackClass": { "type": "string", "description": "Reference into attack-catalog.md (e.g. A. Injection / D. Access Control)" },
          "location": {
            "type": "object",
            "minProperties": 1,
            "description": "At least one of file/endpoint/surface must identify where the finding is.",
            "properties": {
              "file": { "type": "string" },
              "line": { "type": "integer" },
              "endpoint": { "type": "string" },
              "surface": { "type": "string" }
            }
          },
          "description": { "type": "string" },
          "impact": { "type": "string" },
          "evidence": { "type": "string", "description": "How found; safe PoC steps in prose. NEVER include secret values or live PII — describe a credential's type/source, not its value." },
          "remediation": { "type": "string" },
          "compliance": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["framework", "control", "status"],
              "properties": {
                "framework": { "type": "string" },
                "control": { "type": "string" },
                "status": { "enum": ["gap", "covered", "partial"] }
              }
            }
          }
        }
      }
    },
    "accessibilityMap": {
      "type": "array",
      "description": "Inventory of surfaces; see accessibility-map.md",
      "items": {
        "type": "object",
        "required": ["surface", "exposure"],
        "properties": {
          "surface": { "type": "string" },
          "exposure": { "enum": ["public", "authenticated", "role-restricted", "internal-only", "localhost"] },
          "authN": { "type": "string" },
          "authZ": { "type": "string" },
          "sensitivity": { "enum": ["public", "internal", "confidential", "secret-pii-regulated"] },
          "intended": { "type": "boolean" },
          "rateLimited": { "type": "boolean" },
          "findingRef": { "type": "string" },
          "notes": { "type": "string" }
        }
      }
    }
  }
}
